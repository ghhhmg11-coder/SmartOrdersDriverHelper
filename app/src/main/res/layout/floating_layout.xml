<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/floating_bg"
    android:padding="8dp">

    <ImageButton
        android:id="@+id/btn_floating_toggle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_status_off"
        android:background="@drawable/btn_circle_bg"
        android:contentDescription="تبديل التشغيل"/>

    <TextView
        android:id="@+id/tv_floating_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✗"
        android:textColor="@color/gold_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp"/>

</LinearLayout>
