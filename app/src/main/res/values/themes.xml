<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.JeenyUltimateHelper" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold_primary</item>
        <item name="colorPrimaryVariant">@color/gold_dark</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSecondary">@color/gold_light</item>
        <item name="colorOnSecondary">@color/bg_dark</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_card</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="tabStyle">@style/CustomTabStyle</item>
    </style>

    <style name="CustomTabStyle" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabTextColor">@color/text_dim</item>
        <item name="tabSelectedTextColor">@color/gold_primary</item>
        <item name="tabIndicatorColor">@color/gold_primary</item>
        <item name="tabBackground">@color/bg_card</item>
    </style>
</resources>
